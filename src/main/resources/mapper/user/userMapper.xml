<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.pcwk.ehr.user.mapper.UserMapper">

    <!-- DB 컬럼명과 Java 필드명 연결 -->
    <resultMap id="userResultMap" type="com.pcwk.ehr.user.domain.UserVO">
        <id     property="userNum"    column="USER_NUM" />
        <result property="userId"     column="USER_ID" />
        <result property="password"   column="PASSWORD" />
        <result property="userName"   column="USER_NAME" />
        <result property="nickname"   column="NICKNAME" />
        <result property="phoneNum"   column="PHONE_NUM" />
        <result property="email"      column="EMAIL" />
        <result property="birthDt"    column="BIRTH_DT" />
        <result property="userRole"   column="USER_ROLE" />
        <result property="userStatus" column="USER_STATUS" />
        <result property="createDt"   column="CREATE_DT" />
        <result property="updateDt"   column="UPDATE_DT" />
        <result property="withdrawDt" column="WITHDRAW_DT" />
    </resultMap>

    <!--
        여러 SELECT에서 반복 사용하는 컬럼 목록: 여러 번 쓰면 수정할 때 실수하기 쉬우므로 <sql>로 빼둠
    -->
    <sql id="userColumns">
        USER_NUM,
        USER_ID,
        PASSWORD,
        USER_NAME,
        NICKNAME,
        PHONE_NUM,
        EMAIL,
        BIRTH_DT,
        USER_ROLE,
        USER_STATUS,
        CREATE_DT,
        UPDATE_DT,
        WITHDRAW_DT
    </sql>

    <!--
        관리자 회원목록 검색 조건

        <where> 태그:
        - 조건이 있으면 WHERE를 자동으로 붙임
        - 조건이 없으면 WHERE를 붙이지 않음

        <choose> 태그:
        - searchDiv 값에 따라 검색 컬럼을 다르게 함
    -->
    <sql id="userSearchWhere">
        <where>
            <if test="searchWord != null and searchWord != ''">
                <choose>
                    <when test="searchDiv == 'userId'">
                        USER_ID LIKE '%' || #{searchWord} || '%'
                    </when>
                    <when test="searchDiv == 'userName'">
                        USER_NAME LIKE '%' || #{searchWord} || '%'
                    </when>
                    <when test="searchDiv == 'nickname'">
                        NICKNAME LIKE '%' || #{searchWord} || '%'
                    </when>
                    <when test="searchDiv == 'phoneNum'">
                        PHONE_NUM LIKE '%' || #{searchWord} || '%'
                    </when>
                    <when test="searchDiv == 'email'">
                        EMAIL LIKE '%' || #{searchWord} || '%'
                    </when>
                    <when test="searchDiv == 'userStatus'">
                        USER_STATUS = #{searchWord}
                    </when>
                    <otherwise>
                        (
                            USER_ID LIKE '%' || #{searchWord} || '%'
                            OR USER_NAME LIKE '%' || #{searchWord} || '%'
                            OR NICKNAME LIKE '%' || #{searchWord} || '%'
                            OR PHONE_NUM LIKE '%' || #{searchWord} || '%'
                            OR EMAIL LIKE '%' || #{searchWord} || '%'
                        )
                    </otherwise>
                </choose>
            </if>
        </where>
    </sql>
    <!-- 회원가입 INSERT -->
    <insert id="insertUser" parameterType="com.pcwk.ehr.user.domain.UserVO">
        INSERT INTO USER_INFO (
            USER_NUM,
            USER_ID,
            PASSWORD,
            USER_NAME,
            NICKNAME,
            PHONE_NUM,
            EMAIL,
            BIRTH_DT,
            USER_ROLE,
            USER_STATUS,
            CREATE_DT
        ) VALUES (
            SEQ_USER_INFO.NEXTVAL,
            #{userId,jdbcType=VARCHAR},
            #{password,jdbcType=VARCHAR},
            #{userName,jdbcType=NVARCHAR},
            #{nickname,jdbcType=NVARCHAR},
            #{phoneNum,jdbcType=VARCHAR},
            #{email,jdbcType=VARCHAR},
            #{birthDt,jdbcType=DATE},
            NVL(#{userRole,jdbcType=VARCHAR}, '01'),
            NVL(#{userStatus,jdbcType=VARCHAR}, '01'),
            SYSDATE
        )
    </insert>

    <!--
        USER_NUM으로 회원 단건 조회
        - 마이페이지, 회원정보 수정 화면, 관리자 회원상세, 비밀번호 변경, 회원탈퇴에서 사용
    -->
    <select id="selectByUserNum" parameterType="long" resultMap="userResultMap">
        SELECT
            <include refid="userColumns" />
        FROM USER_INFO
        WHERE USER_NUM = #{userNum}
    </select>

    <!--
        USER_ID로 회원 단건 조회
        - 로그인에서 사용
        - 여기에는 USER_STATUS <> '02' 조건을 걸지 않음
          -> 탈퇴 회원도 조회한 뒤 "탈퇴 처리된 회원입니다." 메시지를 줄 수 있음
    -->
    <select id="selectByUserId" parameterType="string" resultMap="userResultMap">
        SELECT
            <include refid="userColumns" />
        FROM USER_INFO
        WHERE USER_ID = #{userId,jdbcType=VARCHAR}
        ORDER BY
            CASE USER_STATUS
                WHEN '01' THEN 1  /* 정상 회원 우선 */
                WHEN '03' THEN 2  /* 휴면 회원 */
                WHEN '04' THEN 3  /* 정지 회원 */
                WHEN '02' THEN 4  /* 탈퇴 회원은 가장 뒤 */
                ELSE 5
            END,
            USER_NUM DESC
        FETCH FIRST 1 ROWS ONLY
    </select>

    <!--
        회원가입 아이디 중복 확인
        - 02 탈퇴 회원은 중복 검사에서 제외
    -->
    <select id="countByUserId" parameterType="string" resultType="int">
        SELECT COUNT(*)
        FROM USER_INFO
        WHERE USER_ID = #{userId,jdbcType=VARCHAR}
          AND USER_STATUS &lt;&gt; '02'
    </select>

    <!--
        회원가입 전화번호 중복 확인
        - 02 탈퇴 회원은 중복 검사에서 제외
    -->
    <select id="countByPhoneNum" parameterType="string" resultType="int">
        SELECT COUNT(*)
        FROM USER_INFO
        WHERE PHONE_NUM = #{phoneNum,jdbcType=VARCHAR}
          AND USER_STATUS &lt;&gt; '02'
    </select>

    <!--
        회원가입 이메일 중복 확인
        - EMAIL은 선택값이므로 Service에서 email이 비어 있지 않을 때만 호출
        - 02 탈퇴 회원은 중복 검사에서 제외
    -->
    <select id="countByEmail" parameterType="string" resultType="int">
        SELECT COUNT(*)
        FROM USER_INFO
        WHERE EMAIL = #{email,jdbcType=VARCHAR}
          AND USER_STATUS &lt;&gt; '02'
    </select>

    <!--
        회원정보 수정 시 전화번호 중복 검사
        - PHONE_NUM = #{phoneNum}: 같은 전화번호를 가진 회원이 있는지 확인
        - USER_NUM != #{userNum}: 자기 자신은 제외
        - USER_STATUS <> '02': 탈퇴 회원은 제외
    -->
    <select id="countByPhoneNumForUpdate"
            parameterType="com.pcwk.ehr.user.domain.UserVO"
            resultType="int">
        SELECT COUNT(*)
        FROM USER_INFO
        WHERE PHONE_NUM = #{phoneNum,jdbcType=VARCHAR}
          AND USER_NUM != #{userNum,jdbcType=NUMERIC}
          AND USER_STATUS &lt;&gt; '02'
    </select>

    <!--
        회원정보 수정 시 이메일 중복 검사
        - 전화번호 수정 중복 검사와 같은 구조
    -->
    <select id="countByEmailForUpdate"
            parameterType="com.pcwk.ehr.user.domain.UserVO"
            resultType="int">
        SELECT COUNT(*)
        FROM USER_INFO
        WHERE EMAIL = #{email,jdbcType=VARCHAR}
          AND USER_NUM != #{userNum,jdbcType=NUMERIC}
          AND USER_STATUS &lt;&gt; '02'
    </select>

    <!--
        일반 회원정보 수정
        - 아이디, 권한, 상태는 일반 회원 수정 불가
    -->
    <update id="updateUser" parameterType="com.pcwk.ehr.user.domain.UserVO">
        UPDATE USER_INFO
        SET
            USER_NAME = #{userName,jdbcType=NVARCHAR},
            NICKNAME = #{nickname,jdbcType=NVARCHAR},
            PHONE_NUM = #{phoneNum,jdbcType=VARCHAR},
            EMAIL = #{email,jdbcType=VARCHAR},
            BIRTH_DT = #{birthDt,jdbcType=DATE},
            UPDATE_DT = SYSDATE
        WHERE USER_NUM = #{userNum,jdbcType=NUMERIC}
    </update>

    <!--
        비밀번호 변경
        - Service에서 새 비밀번호를 해시 처리해서 전달
    -->
    <update id="updatePassword" parameterType="com.pcwk.ehr.user.domain.UserVO">
        UPDATE USER_INFO
        SET
            PASSWORD = #{password,jdbcType=VARCHAR},
            UPDATE_DT = SYSDATE
        WHERE USER_NUM = #{userNum,jdbcType=NUMERIC}
    </update>

    <!-- 회원 탈퇴 -->
    <update id="withdrawUser" parameterType="long">
        UPDATE USER_INFO
        SET
            USER_STATUS = '02',
            WITHDRAW_DT = SYSDATE,
            UPDATE_DT = SYSDATE
        WHERE USER_NUM = #{userNum}
    </update>

    <!-- 관리자 회원목록 조회 -->
    <select id="selectUserList" parameterType="com.pcwk.ehr.user.domain.UserSearchDTO" resultMap="userResultMap">
        SELECT *
        FROM (
            SELECT ROWNUM AS RN, A.*
            FROM (
                SELECT
                    <include refid="userColumns" />
                FROM USER_INFO
                <include refid="userSearchWhere" />
                ORDER BY CREATE_DT DESC, USER_NUM DESC
            ) A
            WHERE ROWNUM &lt;= #{endRow}
        )
        WHERE RN &gt;= #{startRow}
    </select>

    <!-- 관리자 회원목록 총 건수 조회 -->
    <select id="selectUserTotalCount" parameterType="com.pcwk.ehr.user.domain.UserSearchDTO" resultType="int">
        SELECT COUNT(*)
        FROM USER_INFO
        <include refid="userSearchWhere" />
    </select>

    <!--
        관리자 회원상태 변경
        - 02 탈퇴로 바뀌면 WITHDRAW_DT도 함께 저장
        - 01 정상/03 휴면/04 정지로 바뀌면 WITHDRAW_DT는 null 처리
    -->
    <update id="updateUserStatus" parameterType="com.pcwk.ehr.user.domain.UserVO">
        UPDATE USER_INFO
        SET
            USER_STATUS = #{userStatus,jdbcType=VARCHAR},
            WITHDRAW_DT =
                CASE
                    WHEN #{userStatus,jdbcType=VARCHAR} = '02' THEN SYSDATE
                    ELSE NULL
                END,
            UPDATE_DT = SYSDATE
        WHERE USER_NUM = #{userNum,jdbcType=NUMERIC}
    </update>

    <!-- 관리자 회원권한 변경 -->
    <update id="updateUserRole" parameterType="com.pcwk.ehr.user.domain.UserVO">
        UPDATE USER_INFO
        SET
            USER_ROLE = #{userRole,jdbcType=VARCHAR},
            UPDATE_DT = SYSDATE
        WHERE USER_NUM = #{userNum,jdbcType=NUMERIC}
    </update>

</mapper>
