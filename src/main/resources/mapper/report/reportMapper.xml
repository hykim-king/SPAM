<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pcwk.ehr.report.mapper.ReportMapper">
	
	<resultMap id="reportMap" type="ReportVO">
        <id     property="reportNo"       column="REPORT_NO" />
        <result property="reporterNo"     column="REPORTER_NO" />
        <result property="reportedUserNo" column="REPORTED_USER_NO" />
        <result property="adminNo"        column="ADMIN_NO" />
        <result property="reportType"     column="REPORT_TYPE" />
        <result property="targetId"       column="TARGET_ID" />
        <result property="reason"         column="REASON" />
        <result property="reportStatus"   column="REPORT_STATUS" />
        <result property="createDt"       column="CREATE_DT" />
        <result property="processDt"      column="PROCESS_DT" />
    </resultMap>

    <insert id="insertReport" parameterType="ReportVO">
        INSERT INTO REPORT_INFO (
            REPORT_NO, REPORTER_NO, REPORTED_USER_NO, REPORT_TYPE, 
            TARGET_ID, REASON, REPORT_STATUS
        ) VALUES (
            SEQ_REPORT_INFO.NEXTVAL, #{reporterNo}, #{reportedUserNo}, #{reportType},
            #{targetId}, #{reason}, #{reportStatus}
        )
    </insert>
    
    <update id="updateReportStatus" parameterType="ReportVO">
        UPDATE REPORT_INFO
        SET REPORT_STATUS = #{reportStatus},
            PROCESS_DT = SYSDATE,
            ADMIN_NO = #{adminNo}
        WHERE REPORT_NO = #{reportNo}
    </update>
    
   <!-- 단건 삭제 -->
    <delete id="deleteReport" parameterType="ReportVO">
        DELETE FROM REPORT_INFO WHERE REPORT_NO = #{reportNo}
    </delete>

    <!-- 단건 조회 -->
    <select id="doSelectOne" parameterType="ReportVO" resultMap="reportMap">
        SELECT * FROM REPORT_INFO WHERE REPORT_NO = #{reportNo}
    </select>

    <!-- 목록 조회 (기본) -->
    <select id="doRetrieve" parameterType="ReportSearchDTO" resultMap="reportMap">
        SELECT * FROM REPORT_INFO
    </select>

    <!-- 전체 건수 -->
    <select id="totalCnt" resultType="int">
        SELECT COUNT(*) FROM REPORT_INFO
    </select> 
    
    <!-- 전체 삭제 -->
    <delete id="deleteAll">
    	DELETE FROM REPORT_INFO
	</delete>
</mapper>