<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:aop="http://www.springframework.org/schema/aop"
    xmlns:context="http://www.springframework.org/schema/context"
    xmlns:tx="http://www.springframework.org/schema/tx"
    xsi:schemaLocation="http://www.springframework.org/schema/beans https://www.springframework.org/schema/beans/spring-beans.xsd
        http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context-4.3.xsd
        http://www.springframework.org/schema/aop http://www.springframework.org/schema/aop/spring-aop-4.3.xsd
        http://www.springframework.org/schema/tx http://www.springframework.org/schema/tx/spring-tx-4.3.xsd">

    <!-- root-context만 읽는 JUnit에서도 Service를 Bean으로 등록하기 위해 서비스 패키지를 스캔 -->
    <context:component-scan base-package="com.pcwk.ehr.user.service" />
    <context:component-scan base-package="com.pcwk.ehr.report.service" />
    <context:component-scan base-package="com.pcwk.ehr.transact.service" />
    <context:component-scan base-package="com.pcwk.ehr.product.service" />
    <context:component-scan base-package="com.pcwk.ehr.category.service" />
    <context:component-scan base-package="com.pcwk.ehr.chat.service" />

    <!-- MyBatis설정 -->
    <!-- @Mapper interface -->
    <bean class="org.mybatis.spring.mapper.MapperScannerConfigurer">
        <!-- 일괄 빈 등록: 지정한 패키지 내의 모든 매퍼 인터페이스를 자동으로 찾아 Spring bean 등록 -->
        <property name="basePackage" value="com.pcwk.ehr.user.mapper, com.pcwk.ehr.chat.mapper,
                                            com.pcwk.ehr.report.mapper, com.pcwk.ehr.transact.mapper,
                                            com.pcwk.ehr.product.mapper, com.pcwk.ehr.category.mapper"></property>

        <!-- 연결할 SqlSessionFactory의 빈 이름을 지정 : 선택 -->
        <property name="sqlSessionFactoryBeanName" value="sqlSessionFactoryBean"></property>
    </bean>

    <!-- SqlSessionTemplate -->
    <bean id="sqlSessionTemplate" class="org.mybatis.spring.SqlSessionTemplate">
        <constructor-arg index="0" ref="sqlSessionFactoryBean" />
    </bean>

    <!-- SqlSessionFactoryBean -->
    <bean id="sqlSessionFactoryBean" class="org.mybatis.spring.SqlSessionFactoryBean">
        <property name="dataSource" ref="dataSource" />

        <!-- mybatis-config.xml -->
        <property name="configLocation" value="classpath:mybatis-config.xml" />

        <!-- mapper : sql -->
        <property name="mapperLocations" value="classpath:mapper/**/*.xml" />
    </bean>
<!--
    [수정]
    수업용 AOP 트랜잭션 설정은 up* 메서드를 REQUIRES_NEW로 실행합니다.

    기존 설정:
    execution(* com.pcwk.ehr..service.*Impl.up*(..))

    문제:
    - updateUser()
    - updatePassword()
    - updateUserStatus()
    - updateUserRole()

    위 메서드들도 up으로 시작하기 때문에 의도치 않게 AOP 트랜잭션 대상이 됩니다.

    JUnit 테스트에서는 @Transactional @Rollback 환경에서 INSERT 후 UPDATE를 검증하는데,
    updateUser()가 REQUIRES_NEW 새 트랜잭션으로 실행되면
    테스트 트랜잭션에서 아직 commit되지 않은 회원 데이터를 볼 수 없어 UPDATE 건수가 0이 됩니다.

    따라서 회원관리 프로젝트에서는 XML AOP 트랜잭션 대신
    Service 메서드의 @Transactional을 사용합니다.
-->

<!--
    <aop:config>
        <aop:pointcut
            expression="execution(* com.pcwk.ehr..service.*Impl.up*(..))"
            id="txPointcut" />
        <aop:advisor advice-ref="txAdvice" pointcut-ref="txPointcut" />
    </aop:config>

    <tx:advice id="txAdvice" transaction-manager="transactionManager">
        <tx:attributes>
            <tx:method name="up*" propagation="REQUIRES_NEW" isolation="SERIALIZABLE" />
            <tx:method name="*" propagation="REQUIRED" read-only="true" />
        </tx:attributes>
    </tx:advice>
 -->

    <!-- 트랜잭션 어노테이션 활성화 : @Transactional -->
    <tx:annotation-driven proxy-target-class="true" transaction-manager="transactionManager" />

    <bean id="transactionManager" class="org.springframework.jdbc.datasource.DataSourceTransactionManager">
        <constructor-arg name="dataSource" ref="dataSource" />
    </bean>
